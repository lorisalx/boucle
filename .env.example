# Core

# HTTP port for the API, web app, and MCP endpoint; defaults to 4419.
# BOUCLE_PORT=4419
# SQLite path; defaults to $XDG_DATA_HOME/boucle/boucle.db or $HOME/.local/share/boucle/boucle.db.
# BOUCLE_DB=/absolute/path/to/boucle.db
# Markdown brain root; defaults to the bundled fake-brain directory and enables demo mode.
# BOUCLE_BRAIN_DIR=/absolute/path/to/brain
# Bearer token for /mcp; generated once into SQLite when unset.
# BOUCLE_MCP_TOKEN=replace_with_a_random_token
# Base data directory used by the default SQLite path; normally inherited from the process.
# XDG_DATA_HOME=/absolute/path/to/data
# Home directory used for fallback storage and path redaction; normally inherited from the process.
# HOME=/home/you

# Identity

# App name shown in the web UI; defaults to Boucle.
# BOUCLE_APP_NAME=Boucle
# Owner name shown in the UI and used in prompts; defaults to the demo owner only in demo mode.
# BOUCLE_OWNER_NAME=Alex
# Organization name shown in the UI and used in prompts; defaults to the demo organization only in demo mode.
# BOUCLE_ORG_NAME=Example Org

# Provider

# Provider selector; defaults to mistral and also accepts openai.
# BOUCLE_PROVIDER=mistral
# Mistral credential for the default demo, provider calls, legacy chats, and Vibe.
MISTRAL_API_KEY=
# OpenAI-compatible credential; a nonempty value is required when BOUCLE_PROVIDER=openai.
# OPENAI_API_KEY=replace_with_your_key
# OpenAI-compatible API root; defaults to https://api.openai.com/v1.
# OPENAI_BASE_URL=https://api.openai.com/v1
# Chat model override; required when BOUCLE_PROVIDER=openai.
# BOUCLE_CHAT_MODEL=mistral-medium-3.5
# Embedding model override; defaults depend on the provider.
# BOUCLE_EMBED_MODEL=mistral-embed
# Transcription model override; defaults depend on the provider.
# BOUCLE_TRANSCRIBE_MODEL=voxtral-mini-latest

# Vibe

# Agent runner selector; defaults to vibe and no other value is supported yet.
# BOUCLE_RUNNER=vibe
# Vibe executable path; defaults to $HOME/.local/bin/vibe or vibe on PATH.
# BOUCLE_VIBE_BIN=/absolute/path/to/vibe
# Minutes before a Vibe invocation is terminated; defaults to 12.
# BOUCLE_LOOP_TIMEOUT_MIN=12
# Per-invocation Vibe price ceiling in US dollars; defaults to 0.25.
# BOUCLE_VIBE_MAX_PRICE=0.25
# Cumulative recorded Vibe spend that emits a warning; defaults to 10.
# BOUCLE_AGENT_BUDGET_WARN=10
# Cumulative recorded Vibe spend that blocks new agent invocations; defaults to 30.
# BOUCLE_AGENT_BUDGET_STOP=30
