# Boucle — starter .env.example (finalized with grouping + demo-friendly defaults in workstream 3).
# Copy to .env and fill in what you need; every var below is optional except MISTRAL_API_KEY
# for the bundled demo (Mistral stays the default provider until BOUCLE_PROVIDER changes that).

# Mistral API key — powers spawned chats, embeddings, and voice transcription.
MISTRAL_API_KEY=

# App name shown in the UI (wordmark, page title). Defaults to "Boucle".
BOUCLE_APP_NAME=
# Owner name woven into agent prompts and the UI identity block. Empty outside demo mode.
BOUCLE_OWNER_NAME=
# Organization name woven into agent prompts and the UI identity block. Empty outside demo mode.
BOUCLE_ORG_NAME=

# HTTP port the server listens on. Defaults to 4419.
BOUCLE_PORT=
# SQLite DB path. Defaults to $XDG_DATA_HOME/boucle/boucle.db (fallback ~/.local/share/boucle/boucle.db).
BOUCLE_DB=
# Brain (Markdown notes) root. Defaults to the bundled <repo>/fake-brain demo dataset.
BOUCLE_BRAIN_DIR=
# Bearer token for the /mcp HTTP transport. Generated once into the DB if unset.
BOUCLE_MCP_TOKEN=

# Minutes before a Vibe loop run is considered stuck and killed.
BOUCLE_LOOP_TIMEOUT_MIN=
# Path to the Vibe CLI binary, if not on PATH.
BOUCLE_VIBE_BIN=
# Per-run price ceiling (USD) passed to the Vibe CLI.
BOUCLE_VIBE_MAX_PRICE=
